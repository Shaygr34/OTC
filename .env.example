# Adapter selection (set ATM_USE_IBKR=1 to use real IBKR, otherwise MockAdapter)
ATM_USE_IBKR=0

# IBKR Connection (only used when ATM_USE_IBKR=1)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID_SCANNER=1
IBKR_CLIENT_ID_DATA=2

# Telegram Alerts
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database — PostgreSQL (Railway)
# Engine uses: postgresql+asyncpg://user:pass@host:port/db
# Dashboard uses: postgresql://user:pass@host:port/db (no +asyncpg prefix)
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@HOST.railway.app:PORT/railway

# Risk
RISK_MAX_POSITION_PCT=0.05
RISK_MAX_LOSS_PCT=0.02
RISK_PORTFOLIO_VALUE=10000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
